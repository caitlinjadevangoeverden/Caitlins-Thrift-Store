{
  "expo": {
    "name": "Caitlin van Goeverden",
    "slug": "ClothingApp",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/profile.png",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/profile.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    

    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/profile.png",
        "backgroundColor": "#ffffff"
      }
    },

    "web": {
      "favicon": "./assets/profile.png"
    }
  }
}